# ============================================
# SALESCOACH ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# 1. NODE ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# 2. DATABASE (REQUIRED) ⚠️
# ============================================
# PostgreSQL connection string
#
# If using Replit: This is automatically set, leave blank or remove
# If using Neon.tech (free): Get from https://neon.tech after creating project
# If using local PostgreSQL: Use format below
#
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://myuser:mypassword@localhost:5432/salescoach
#
DATABASE_URL=postgresql://YOUR_USERNAME:YOUR_PASSWORD@YOUR_HOST:5432/salescoach

# ============================================
# 3. AUTHENTICATION SECRET (REQUIRED) ⚠️
# ============================================
# Generate a secure random secret (32+ characters)
#
# TO GENERATE: Run this command in terminal:
#   openssl rand -hex 32
#
# Then paste the output below:
JWT_SECRET=PASTE_YOUR_GENERATED_SECRET_HERE

# ============================================
# 4. OPENAI API (Required for AI Features)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
#
# Steps to get key:
#   1. Go to https://platform.openai.com/signup
#   2. Sign up or log in
#   3. Go to API Keys section
#   4. Click "Create new secret key"
#   5. Copy the key (starts with sk-)
#
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE

# Optional: Use separate key for AI hints (or use same as above)
OPEN_AI_BRN_ASST=sk-YOUR_OPENAI_API_KEY_HERE

# ============================================
# 5. VAPI AI (Required for Voice Training)
# ============================================
# Get your API key from: https://vapi.ai/dashboard
#
# Steps to get key:
#   1. Go to https://vapi.ai
#   2. Sign up for free trial
#   3. Go to Dashboard
#   4. Copy your API key
#
VAPI_API_KEY=YOUR_VAPI_API_KEY_HERE

# ============================================
# 6. GOOGLE CLOUD STORAGE (Optional - can skip initially)
# ============================================
# Only needed if you want file upload features
# Can add these later when you set up Google Cloud
#
# PUBLIC_OBJECT_SEARCH_PATHS=gs://your-bucket-name/public
# PRIVATE_OBJECT_DIR=gs://your-bucket-name/private

# ============================================
# 7. CORS - PRODUCTION ONLY (Leave blank for development)
# ============================================
# Only set this when deploying to production
# Comma-separated list of allowed domains
#
# Example: ALLOWED_ORIGINS=https://salescoach.com,https://app.salescoach.com
#
ALLOWED_ORIGINS=

# ============================================
# 8. REPLIT SPECIFIC (Auto-set by Replit)
# ============================================
# These are automatically set by Replit - don't modify
# REPL_ID=
# REPLIT_DEPLOYMENT=

# ============================================
# SETUP CHECKLIST
# ============================================
# ✅ Step 1: Copy this file to .env
# ✅ Step 2: Generate JWT_SECRET (openssl rand -hex 32)
# ✅ Step 3: Set DATABASE_URL
# ✅ Step 4: Get OPENAI_API_KEY from platform.openai.com
# ✅ Step 5: Get VAPI_API_KEY from vapi.ai
# ✅ Step 6: Save file
# ✅ Step 7: Run: npm run db:push
# ✅ Step 8: Run: npm run dev
# ✅ Step 9: Open: http://localhost:5000
