# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=5000

# Allowed origins for CORS (comma-separated, only needed in production)
# Example: https://salescoach.com,https://app.salescoach.com
ALLOWED_ORIGINS=

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?sslmode=require
# Example: postgresql://user:pass@localhost:5432/salescoach
DATABASE_URL=postgresql://username:password@host:port/database

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Secret - Generate a strong random string
# Use: openssl rand -hex 32
JWT_SECRET=your-very-secure-random-secret-key-here-replace-in-production

# ============================================
# AI SERVICES
# ============================================
# OpenAI API Key for chat and AI features
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Assistant Key (if using separate account for hints)
# Optional - can use same as OPENAI_API_KEY
OPEN_AI_BRN_ASST=sk-your-openai-assistant-key-here

# ============================================
# VOICE TRAINING (VAPI.ai)
# ============================================
# VAPI API Key for voice training features
# Get from: https://vapi.ai/dashboard
VAPI_API_KEY=your-vapi-api-key-here

# ============================================
# OBJECT STORAGE (Google Cloud / Replit)
# ============================================
# Comma-separated list of public object storage paths
# Example: gs://bucket-name/public,gs://another-bucket/assets
PUBLIC_OBJECT_SEARCH_PATHS=gs://your-bucket-name/public

# Private object storage directory for uploaded files
# Example: gs://bucket-name/private
PRIVATE_OBJECT_DIR=gs://your-bucket-name/private

# ============================================
# REPLIT SPECIFIC (Optional)
# ============================================
# Automatically set by Replit - do not modify
# REPL_ID=
# REPLIT_DEPLOYMENT=
